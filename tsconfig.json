{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    /* Base Options: */
    "skipLibCheck": true,
    "target": "es2022",
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "erasableSyntaxOnly": true,
    "exactOptionalPropertyTypes": false,
    /* TypeScript transpiling */
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@emails/*": ["src/emails/*"],
      "@i18n/*": ["src/i18n/*"],
      "@layouts/*": ["src/layouts/*"],
      "@collections/*": ["src/collections/*"],
      "@pages/*": ["src/pages/*"],
      "@public/*": ["public/*"],
      //@types is reserved for type declaration packages installed from bun - so I use a different alias
      "@customTypes/*": ["src/customTypes/*"],
      "@utils/*": ["src/utils/*"],
      "@scripts/*": ["src/scripts/*"]
    },
    "lib": ["DOM", "ES2017", "ES2022"],
    "removeComments": false,
    "preserveConstEnums": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "plugins": [{ "name": "@astrojs/ts-plugin" }]
  },
  "exclude": [   
    "node_modules",
    "src/pages/api/**/*.html",
    "src/pages/api/**/templates/**/*.handlebars"],
    "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mts",
    "src/**/*.astro",
    "src/**/*.d.ts"
  ],
  "$schema": "https://json.schemastore.org/tsconfig"
}
