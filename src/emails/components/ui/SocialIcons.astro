---
import Column from '@emails/components/primitives/Column.astro';
import Link from '@emails/components/primitives/Link.astro';
import Row from '@emails/components/primitives/Row.astro';
import Image from '@emails/components/primitives/Image.astro';

type Props = {
  socialLinks: EmailImageLink[];
};

export type EmailImage = {
  src: string;
  alt: string;
};

export type EmailImageLink = EmailImage & {
  href: string;
};

const { socialLinks } = Astro.props;
---

<Row width={55 * socialLinks.length}>
  {
    socialLinks.map(({ href, src, alt }) => (
      <Column
        class="img"
        width={55}
        style="font-size: 0pt; line-height: 0pt; text-align: center;"
      >
        <Link href={href} rel="noopener noreferrer">
          <Image src={src} width={32} height={32} alt={alt} />
        </Link>
      </Column>
    ))
  }
</Row>
